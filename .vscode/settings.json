{
  "code-runner.runInTerminal": true,
  "code-runner.executorMap": {
    "cpp": "cd $dir && /usr/bin/clang++ -std=c++17 -I /Library/Developer/CommandLineTools/SDKs/MacOSX.sdk/usr/include/c++/v1 -isysroot /Library/Developer/CommandLineTools/SDKs/MacOSX.sdk $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt"
  }
}
